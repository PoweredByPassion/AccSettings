    <string name="hint_between">介于 %1$d 和 %2$d 之间！</string>
    <string name="hint_capacity_shutdown">仅在放电且运行超过15分钟时有效。</string>
    <string name="hint_cooldown">周期性充电和暂停。\n减少持续高温和高压造成的损害。</string>
    <string name="hint_prevent_shutdown">同时防止关机。</string>
    <string name="hint_period">每个周期的秒数</string>
    <string name="hint_charge_period">未设置时冷却功能关闭。\n建议设置为50。</string>
    <string name="hint_cooldown_period">在每个周期中暂停（或限制，如设置了冷却电流）充电。\n未设置时冷却功能关闭。\n建议设置为10。\n如果充电太慢则调低。</string>
    <string name="hint_cooldown_current">在冷却期间限制充电而非暂停。</string>
    <string name="hint_idle_mode">与某些三星及其他设备不兼容。</string>
    <string name="hint_strict_current_control">仅使用匹配\"batt\"的控制文件。\n当电流限制同时影响输入和充电电流时需要启用。</string>
    <string name="hint_capacity_mask">让 Android 继续显示常规 0-100 电量，而不是 ACC 限制后的暂停区间。</string>
    <string name="hint_allow_idle_above_pause_capacity">常插电设备如果不想长期停在高电量，可关闭这一项。</string>
    <string name="hint_prioritize_batt_idle_mode">只影响自动检测充电开关时的优先级。可用时优先选择支持空闲模式的开关。</string>
    <string name="hint_off_mid">系统重启或守护进程重启后，如果电量仍在恢复和暂停阈值之间，则再次关闭充电。</string>
    <string name="hint_reboot_resume">只有在设备无法直接重新开启充电时才使用。</string>
    <string name="hint_batt_status_workaround">不要只信任电池状态文件，而是辅助判断 Idle 和 Discharging，提高兼容性。</string>
    <string name="hint_force_off">当系统总是把充电重新打开时，作为最后手段再开启。</string>
    <string name="hint_max_charging_current">支持普通值和 ACC 高级语法。这里保留文本输入，避免数组或特殊格式被截断。</string>
    <string name="hint_max_charging_voltage">适合直接设置电压上限。更复杂的数组语法仍可能需要直接编辑配置。</string>
    <string name="hint_temp_level">某些内核或三星风格控制使用的另一套限流后端。</string>
    <string name="hint_apply_on_boot">ACC 的开机应用原始语法。守护进程启动或重启时会执行。</string>
    <string name="hint_apply_on_plug">ACC 的插电应用原始语法。充电期间会周期性重新应用。</string>
    <string name="hint_idle_apps">逗号或空格分隔的 Android 包名模式，命中前台应用时触发空闲模式。</string>
    <string name="hint_run_on_pause">充电暂停后由 ACC 执行的 shell 命令或脚本。</string>
    <string name="hint_batt_status_override">只建议在强制指定充电开关时使用，帮助 ACC 判断 Idle 或 Discharging。</string>
    <string name="hint_amp_factor">只有在 ACC 报错电流单位时才改。</string>
    <string name="hint_volt_factor">只有在 ACC 报错电压单位时才改。</string>

