    <string name="hint_between">Between %1$d and %2$d!</string>
    <string name="hint_capacity_shutdown">Only valid when discharging and running more than 15 minutes.</string>
    <string name="hint_cooldown">Periodically charge and pause.\nReduce damage from prolonged high temperature and voltage.</string>
    <string name="hint_prevent_shutdown">Also prevent shutdown.</string>
    <string name="hint_period">Second(s) during each cycle</string>
    <string name="hint_charge_period">Cooldown disabled if unset.\n50 suggested if set.</string>
    <string name="hint_cooldown_period">Pause (or limit if set cooldown current) charging during each cycle.\nCooldown disabled if unset.\n10 suggested if set.\nTurn down if charge too slow.</string>
    <string name="hint_cooldown_current">Limit charging instead of pausing during cooldown period.</string>
    <string name="hint_idle_mode">Incompatible with some Samsung and other devices.</string>
    <string name="hint_strict_current_control">Only use control files match \"batt\".\nNeed if current limit affects both input and charging current.</string>
    <string name="hint_capacity_mask">Make Android show a normal 0-100 style battery scale instead of the restricted ACC pause range.</string>
    <string name="hint_allow_idle_above_pause_capacity">Turn this off for always-plugged setups when keeping a high charge for long periods is a concern.</string>
    <string name="hint_prioritize_batt_idle_mode">Only affects automatic switch detection. Prefer idle-mode capable switches when available.</string>
    <string name="hint_off_mid">After reboot or daemon restart, stop charging again if the battery is still between resume and pause thresholds.</string>
    <string name="hint_reboot_resume">Only use this on devices that cannot re-enable charging without a reboot.</string>
    <string name="hint_batt_status_workaround">Improves compatibility by inferring Idle and Discharging states instead of trusting battery status alone.</string>
    <string name="hint_force_off">Last-resort option when the system keeps turning charging back on.</string>
    <string name="hint_max_charging_current">Supports plain values and ACC advanced syntax. Use text mode here so arrays and special forms still fit.</string>
    <string name="hint_max_charging_voltage">Best for straightforward voltage caps. Complex ACC array syntax may still require direct config editing.</string>
    <string name="hint_temp_level">Alternate current-limiting back end used by some kernels and Samsung-style controls.</string>
    <string name="hint_apply_on_boot">Raw ACC apply-on-boot syntax. Settings are applied when the daemon starts or restarts.</string>
    <string name="hint_apply_on_plug">Raw ACC apply-on-plug syntax. These values are re-applied while charging.</string>
    <string name="hint_idle_apps">Comma- or space-separated Android package patterns that should trigger idle mode in the foreground.</string>
    <string name="hint_run_on_pause">Shell command or script ACC should run after charging is paused.</string>
    <string name="hint_batt_status_override">Use only with an enforced charging switch when ACC needs help deciding between Idle and Discharging.</string>
    <string name="hint_amp_factor">Override only if ACC reports the wrong current units.</string>
    <string name="hint_volt_factor">Override only if ACC reports the wrong voltage units.</string>

